<header class="sticky top-0 z-30 border-b border-white/70 bg-white/80 backdrop-blur-xl">
  <div class="container-shell flex flex-wrap items-center justify-between gap-3 py-3">
    <a href="/" class="flex items-center gap-3">
      <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-orange-500 to-amber-500 text-sm font-bold text-white shadow-md shadow-orange-200">C</span>
      <span class="font-display text-xl font-bold text-slate-900">CookBook</span>
    </a>

    <nav class="flex flex-wrap items-center gap-1">
      
      <% if (currentUser) { %>
        <a class="nav-link" href="/recipes">Recetas</a>
        <a class="nav-link" href="/recipes/new">Nueva receta</a>
        <span class="ml-1 rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
          <%= currentUser.username %>
        </span>
        <form action="/logout" method="POST" class="ml-1 inline">
          <button class="btn-danger" type="submit">Log out</button>
        </form>
      <% } else { %>
        <a class="btn-soft" href="/signup">Signup</a>
        <a class="btn-main ml-1" href="/login">Login</a>
      <% } %>
    </nav>
  </div>
</header>
