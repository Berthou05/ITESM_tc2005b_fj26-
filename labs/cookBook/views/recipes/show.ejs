<%- include('../partials/head', { title }) %>
<%- include('../partials/navbar') %>
<%- include('../partials/alerts') %>

<main class="container-shell py-12">
  <article class="mx-auto overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-[0_26px_70px_-35px_rgba(15,23,42,0.45)]">
    <div class="grid gap-0 lg:grid-cols-[1.05fr_1fr]">
      <figure class="relative min-h-[280px]">
        <img
          src="<%= recipe.image_url || 'https://images.unsplash.com/photo-1495521821757-a1efb6729352?auto=format&fit=crop&w=1400&q=80' %>"
          alt="Imagen de <%= recipe.title %>"
          class="h-full w-full object-cover"
        />
      </figure>

      <div class="p-6 md:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-orange-600">Detalle de receta</p>
        <h1 class="mt-2 text-3xl font-extrabold"><%= recipe.title %></h1>
        <p class="mt-3 text-slate-600"><%= recipe.description || 'Sin descripcion.' %></p>

        <div class="mt-4 rounded-2xl bg-slate-50 px-4 py-3 text-xs text-slate-600">
          <p>Autor: <strong><%= recipe.author_username %></strong></p>
          <p class="mt-1">Creada: <%= new Date(recipe.created_at).toLocaleString() %></p>
        </div>

        <% const ingredientLines = (recipe.ingredients || '').split(/\r?\n/).filter(Boolean); %>
        <% const stepLines = (recipe.steps || '').split(/\r?\n/).filter(Boolean); %>

        <section class="mt-6">
          <h2 class="text-xl font-bold">Ingredientes</h2>
          <ul class="mt-3 space-y-2 text-sm text-slate-700">
            <% ingredientLines.forEach((item) => { %>
              <li class="flex items-start gap-2">
                <span class="mt-1 h-2 w-2 rounded-full bg-amber-500"></span>
                <span><%= item %></span>
              </li>
            <% }) %>
          </ul>
        </section>

        <section class="mt-6">
          <h2 class="text-xl font-bold">Pasos</h2>
          <ol class="mt-3 space-y-2 text-sm text-slate-700">
            <% stepLines.forEach((item, index) => { %>
              <li class="flex gap-3">
                <span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-orange-100 text-xs font-bold text-orange-700"><%= index + 1 %></span>
                <span><%= item %></span>
              </li>
            <% }) %>
          </ol>
        </section>

        <div class="mt-7 flex flex-wrap gap-3">
          <% if (currentUser.privileges && currentUser.privileges.includes('modificar_recetas')) { %>
            <a href="/recipes/<%= recipe.recipe_id %>/edit" class="btn-main">Modificar receta</a>
          <% } %>
          <a href="/recipes" class="btn-soft">Volver a recetas</a>
        </div>
      </div>
    </div>
  </article>
</main>

<%- include('../partials/footer') %>
