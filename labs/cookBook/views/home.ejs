<%- include('partials/head', { title }) %>
<%- include('partials/navbar') %>
<%- include('partials/alerts') %>

<main class="container-shell py-12 md:py-16">
  <section class="panel relative overflow-hidden px-6 py-12 md:px-12">
    <div class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full bg-amber-200/50 blur-3xl"></div>
    <div class="pointer-events-none absolute -left-24 bottom-0 h-56 w-56 rounded-full bg-orange-200/50 blur-3xl"></div>

    <div class="relative max-w-3xl">
      <p class="mb-4 inline-flex rounded-full bg-orange-100 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-orange-700">
        Gestor de recetas
      </p>
      <h1 class="text-4xl font-extrabold leading-tight md:text-5xl">
        Cocina, organiza y comparte tus recetas favoritas
      </h1>
      <p class="mt-5 max-w-2xl text-base leading-relaxed text-slate-600 md:text-lg">
        Guarda tus recetas de cocina en un solo lugar
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <% if (currentUser) { %>
            <a href="/recipes" class="btn-main">Ver recetas</a>
            <a href="/recipes/new" class="btn-soft">Crear receta</a>
        <% } %>
      </div>

      <p class="mt-6 text-xs text-slate-500">Ultima visita: <%= new Date().toLocaleString() %></p>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
