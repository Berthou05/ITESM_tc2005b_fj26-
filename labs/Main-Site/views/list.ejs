<%- include('includes/_header') %>

<section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
  <div class="mb-4 flex items-center justify-between">
    <h2 class="text-lg font-bold text-slate-800">Task list</h2>
    <a href="/tasks/new"
      class="rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700">Nueva task</a>
  </div>

  <% if (!tasks || tasks.length === 0) { %>
  <p class="text-slate-500">No tasks yet.</p>
  <% } else { %>
  <ul class="space-y-3">
    <% tasks.forEach((task) => { %>
    <li class="flex items-center justify-between gap-3 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
      <span class="font-semibold text-slate-800"><%= task.title %></span>
      <span class="shrink-0 rounded-full bg-amber-100 px-3 py-1 text-xs font-bold text-amber-900">
        <%= task.dueDate ? new Date(task.dueDate).toLocaleDateString() : "No due date" %>
      </span>
    </li>
    <% }) %>
  </ul>
  <% } %>
</section>

<%- include('includes/_footer') %>
